# Copy to .env and fill in. The engine reads these at startup.

# Required for the judgment engine to call Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token used by the release go/no-go evidence connector (DF-1).
# A fine-grained PAT with read access to the target repo's contents, issues, and actions.
# Without it, the engine still runs but reports "evidence unavailable" instead of real signals.
GITHUB_TOKEN=

# Where the immutable audit ledger lives. SQLite file by default (zero infra). For a real
# deployment, point at Postgres: DATABASE_URL=postgresql+psycopg://user:pass@host:5432/truenorth
DATABASE_URL=sqlite:///./truenorth.db

# Optional model-routing overrides (defaults shown). Routing is by stakes tier — see config.py.
TRUENORTH_MODEL_S1=claude-opus-4-8
TRUENORTH_MODEL_S2=claude-opus-4-8
TRUENORTH_MODEL_S3=claude-sonnet-4-6
TRUENORTH_MODEL_S4=claude-haiku-4-5

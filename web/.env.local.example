# Engine base URL (FastAPI). Local dev default:
ENGINE_URL=http://127.0.0.1:8000

# Dev API key used by the BFF to call the engine. Mint one with:
#   conda run -n truenorth truenorth-admin mint --subject dev --role admin
ENGINE_API_KEY=

